{
  "$schema": "https://tokens.studio/json-schema/draft-2024-09.json",
  "metadata": {
    "version": "1.0.0",
    "created": "2026-04-18",
    "brand": "Lodgra",
    "status": "production",
    "compliance": "WCAG AA"
  },
  "colors": {
    "primary": {
      "blue": {
        "$value": "#1E3A8A",
        "$type": "color",
        "description": "Azul Confiança - Primary brand color (Trust, professionalism)",
        "hex": "#1E3A8A",
        "rgb": "rgb(30, 58, 138)",
        "hsl": "hsl(220°, 64%, 33%)"
      },
      "gold": {
        "$value": "#D4AF37",
        "$type": "color",
        "description": "Ouro Próspero - Accent color (Prosperity, growth)",
        "hex": "#D4AF37",
        "rgb": "rgb(212, 175, 55)",
        "hsl": "hsl(45°, 78%, 52%)"
      }
    },
    "secondary": {
      "green": {
        "$value": "#059669",
        "$type": "color",
        "description": "Verde Crescimento - Success, growth indicators",
        "hex": "#059669",
        "rgb": "rgb(5, 150, 105)",
        "hsl": "hsl(162°, 93%, 30%)"
      }
    },
    "neutral": {
      "light": {
        "$value": "#F3F4F6",
        "$type": "color",
        "description": "Cinza Neutro Claro - Backgrounds, cards",
        "hex": "#F3F4F6",
        "rgb": "rgb(243, 244, 246)",
        "hsl": "hsl(210°, 11%, 96%)"
      },
      "dark": {
        "$value": "#374151",
        "$type": "color",
        "description": "Cinza Escuro - Body text, headings",
        "hex": "#374151",
        "rgb": "rgb(55, 65, 81)",
        "hsl": "hsl(216°, 19%, 27%)"
      }
    },
    "white": {
      "$value": "#FFFFFF",
      "$type": "color",
      "description": "Branco puro"
    },
    "black": {
      "$value": "#000000",
      "$type": "color",
      "description": "Preto puro"
    },
    "semantic": {
      "success": {
        "$value": "{colors.secondary.green}",
        "$type": "color"
      },
      "warning": {
        "$value": "#D4AF37",
        "$type": "color"
      },
      "error": {
        "$value": "#DC2626",
        "$type": "color"
      },
      "info": {
        "$value": "#1E3A8A",
        "$type": "color"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "heading": {
        "$value": "Poppins, sans-serif",
        "$type": "fontFamily",
        "description": "Bold, modern, warm - for headings"
      },
      "body": {
        "$value": "Inter, sans-serif",
        "$type": "fontFamily",
        "description": "Ultra-legible, screen-optimized - for body text"
      }
    },
    "fontSize": {
      "h1": {
        "$value": "48px",
        "$type": "dimension",
        "description": "Page title (desktop)"
      },
      "h1_mobile": {
        "$value": "32px",
        "$type": "dimension",
        "description": "Page title (mobile)"
      },
      "h2": {
        "$value": "36px",
        "$type": "dimension",
        "description": "Section header (desktop)"
      },
      "h2_mobile": {
        "$value": "24px",
        "$type": "dimension",
        "description": "Section header (mobile)"
      },
      "h3": {
        "$value": "28px",
        "$type": "dimension"
      },
      "h3_mobile": {
        "$value": "20px",
        "$type": "dimension"
      },
      "h4": {
        "$value": "24px",
        "$type": "dimension"
      },
      "body": {
        "$value": "16px",
        "$type": "dimension",
        "description": "Body text (minimum for accessibility)"
      },
      "small": {
        "$value": "14px",
        "$type": "dimension"
      },
      "tiny": {
        "$value": "12px",
        "$type": "dimension"
      }
    },
    "fontWeight": {
      "regular": {
        "$value": "400",
        "$type": "fontWeight"
      },
      "medium": {
        "$value": "500",
        "$type": "fontWeight"
      },
      "semibold": {
        "$value": "600",
        "$type": "fontWeight"
      },
      "bold": {
        "$value": "700",
        "$type": "fontWeight"
      }
    },
    "lineHeight": {
      "tight": {
        "$value": "1.2",
        "$type": "lineHeight"
      },
      "normal": {
        "$value": "1.5",
        "$type": "lineHeight",
        "description": "Minimum for readability"
      },
      "relaxed": {
        "$value": "1.6",
        "$type": "lineHeight",
        "description": "Optimal for body text"
      }
    },
    "letterSpacing": {
      "none": {
        "$value": "0px",
        "$type": "dimension"
      },
      "tight": {
        "$value": "-1px",
        "$type": "dimension",
        "description": "For large headings"
      },
      "loose": {
        "$value": "0.5px",
        "$type": "dimension"
      }
    },
    "textStyle": {
      "h1": {
        "$type": "typography",
        "fontFamily": "{typography.fontFamily.heading}",
        "fontSize": "{typography.fontSize.h1}",
        "fontWeight": "{typography.fontWeight.bold}",
        "lineHeight": "{typography.lineHeight.tight}",
        "letterSpacing": "{typography.letterSpacing.tight}"
      },
      "h1_mobile": {
        "$type": "typography",
        "fontFamily": "{typography.fontFamily.heading}",
        "fontSize": "{typography.fontSize.h1_mobile}",
        "fontWeight": "{typography.fontWeight.bold}",
        "lineHeight": "{typography.lineHeight.tight}",
        "letterSpacing": "{typography.letterSpacing.none}"
      },
      "h2": {
        "$type": "typography",
        "fontFamily": "{typography.fontFamily.heading}",
        "fontSize": "{typography.fontSize.h2}",
        "fontWeight": "{typography.fontWeight.bold}",
        "lineHeight": "{typography.lineHeight.tight}"
      },
      "h2_mobile": {
        "$type": "typography",
        "fontFamily": "{typography.fontFamily.heading}",
        "fontSize": "{typography.fontSize.h2_mobile}",
        "fontWeight": "{typography.fontWeight.bold}",
        "lineHeight": "{typography.lineHeight.tight}"
      },
      "body": {
        "$type": "typography",
        "fontFamily": "{typography.fontFamily.body}",
        "fontSize": "{typography.fontSize.body}",
        "fontWeight": "{typography.fontWeight.regular}",
        "lineHeight": "{typography.lineHeight.relaxed}"
      },
      "small": {
        "$type": "typography",
        "fontFamily": "{typography.fontFamily.body}",
        "fontSize": "{typography.fontSize.small}",
        "fontWeight": "{typography.fontWeight.regular}",
        "lineHeight": "{typography.lineHeight.normal}"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": "4px",
      "description": "Micro spacing (borders, small gaps)"
    },
    "sm": {
      "$value": "8px",
      "description": "Small spacing (component padding)"
    },
    "md": {
      "$value": "16px",
      "description": "Medium spacing (sections)"
    },
    "lg": {
      "$value": "24px",
      "description": "Large spacing (major sections)"
    },
    "xl": {
      "$value": "32px",
      "description": "XL spacing (page breaks)"
    },
    "2xl": {
      "$value": "64px",
      "description": "XXL spacing (hero sections)"
    }
  },
  "borderRadius": {
    "none": {
      "$value": "0px",
      "$type": "dimension"
    },
    "sm": {
      "$value": "8px",
      "$type": "dimension",
      "description": "Small radius (buttons, inputs)"
    },
    "md": {
      "$value": "12px",
      "$type": "dimension",
      "description": "Medium radius (cards)"
    },
    "lg": {
      "$value": "16px",
      "$type": "dimension"
    },
    "full": {
      "$value": "9999px",
      "$type": "dimension",
      "description": "Pill shape"
    }
  },
  "shadow": {
    "sm": {
      "$value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgba(0, 0, 0, 0.1)",
      "$type": "shadow"
    }
  },
  "components": {
    "button": {
      "primary": {
        "background": {
          "$value": "{colors.primary.gold}",
          "$type": "color"
        },
        "color": {
          "$value": "{colors.primary.blue}",
          "$type": "color"
        },
        "padding": {
          "$value": "12px 24px",
          "$type": "dimension"
        },
        "fontSize": {
          "$value": "{typography.fontSize.body}",
          "$type": "dimension"
        },
        "fontWeight": {
          "$value": "{typography.fontWeight.bold}",
          "$type": "fontWeight"
        },
        "borderRadius": {
          "$value": "{borderRadius.sm}",
          "$type": "dimension"
        },
        "hover": {
          "background": {
            "$value": "#E0A627",
            "$type": "color",
            "description": "Gold -10% brightness"
          }
        }
      },
      "secondary": {
        "background": {
          "$value": "{colors.white}",
          "$type": "color"
        },
        "color": {
          "$value": "{colors.primary.blue}",
          "$type": "color"
        },
        "border": {
          "$value": "2px solid {colors.primary.blue}",
          "$type": "stroke"
        },
        "padding": {
          "$value": "12px 24px",
          "$type": "dimension"
        }
      },
      "ghost": {
        "background": {
          "$value": "transparent",
          "$type": "color"
        },
        "color": {
          "$value": "{colors.primary.blue}",
          "$type": "color"
        },
        "padding": {
          "$value": "12px 24px",
          "$type": "dimension"
        }
      }
    },
    "card": {
      "background": {
        "$value": "{colors.white}",
        "$type": "color"
      },
      "border": {
        "$value": "1px solid #E5E7EB",
        "$type": "stroke"
      },
      "borderRadius": {
        "$value": "{borderRadius.md}",
        "$type": "dimension"
      },
      "padding": {
        "$value": "{spacing.lg}",
        "$type": "dimension"
      },
      "shadow": {
        "$value": "{shadow.md}",
        "$type": "shadow"
      }
    },
    "input": {
      "background": {
        "$value": "{colors.white}",
        "$type": "color"
      },
      "border": {
        "$value": "1px solid #E5E7EB",
        "$type": "stroke"
      },
      "borderRadius": {
        "$value": "{borderRadius.sm}",
        "$type": "dimension"
      },
      "padding": {
        "$value": "10px 12px",
        "$type": "dimension"
      },
      "fontSize": {
        "$value": "{typography.fontSize.body}",
        "$type": "dimension"
      },
      "focus": {
        "borderColor": {
          "$value": "{colors.primary.blue}",
          "$type": "color"
        },
        "outline": {
          "$value": "2px solid {colors.primary.gold}",
          "$type": "stroke"
        }
      }
    }
  },
  "accessibility": {
    "contrastRatios": {
      "blue_on_white": {
        "$value": "8.1:1",
        "level": "AAA"
      },
      "blue_on_gray": {
        "$value": "5.2:1",
        "level": "AA"
      },
      "gold_on_white": {
        "$value": "4.6:1",
        "level": "AA"
      },
      "dark_on_white": {
        "$value": "11.2:1",
        "level": "AAA"
      }
    },
    "touchTarget": {
      "minimum": {
        "$value": "44px",
        "description": "Minimum touch target size (mobile WCAG)"
      }
    }
  }
}
