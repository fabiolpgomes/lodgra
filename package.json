{
  "name": "lodgra",
  "version": "1.0.0",
  "description": "Global hospitality SaaS platform - Next.js, Supabase, Stripe",
  "private": true,
  "packageManager": "npm@11.6.2",
  "scripts": {
    "dev": "next dev",
    "dev:prod-db": "bash -c 'set -a && . ./.env.local && . ./.env.local.prod-db && set +a && exec ./node_modules/.bin/next dev'",
    "build": "node scripts/next-build.js",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --ci --forceExit",
    "test:ci": "jest --ci --coverage",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "ANALYZE=true next build",
    "version:tokens": "node scripts/version-tokens.js",
    "version:tokens:check": "node scripts/version-tokens.js --check",
    "version:tokens:patch": "node scripts/version-tokens.js --patch",
    "version:tokens:minor": "node scripts/version-tokens.js --minor",
    "version:tokens:major": "node scripts/version-tokens.js --major",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "tokens:build": "cd packages/design-tokens && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@upstash/qstash": "^2.9.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/blob": "2.4.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "google-auth-library": "10.7.0",
    "handlebars": "4.7.9",
    "heic2any": "0.0.4",
    "ical.js": "^2.2.1",
    "lucide-react": "^0.562.0",
    "mjml": "5.2.2",
    "next": "15.5.18",
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.70.0",
    "react-markdown": "10.1.0",
    "react-swipe-events": "^1.0.3",
    "recharts": "^3.6.0",
    "rehype-sanitize": "6.0.0",
    "remark-gfm": "4.0.1",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.5.0",
    "xml2js": "0.6.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.58.2",
    "@storybook/nextjs": "^10.4.0",
    "@storybook/react": "^10.4.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^15.0.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xml2js": "0.4.14",
    "artillery": "2.0.31",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "playwright": "1.60.0",
    "shadcn": "^3.8.5",
    "storybook": "^10.4.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
