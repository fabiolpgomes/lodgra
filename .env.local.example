# Supabase Configuration
# Após criar seu projeto no Supabase (https://supabase.com), 
# substitua estes valores pelos fornecidos no dashboard

NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Obrigatório: Para gestão de utilizadores
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend) - https://resend.com
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Home Stay <noreply@seudominio.com>
EMAIL_ADMIN=admin@seudominio.com

# Cron Jobs
CRON_SECRET=your-cron-secret

# Stripe (https://stripe.com)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — Per-unit licensed prices (billing_scheme=per_unit, usage_type=licensed)
STRIPE_PRICE_ID_STARTER_EUR=price_...     # €9/unidade/mês
STRIPE_PRICE_ID_GROWTH_EUR=price_...      # €14/unidade/mês
STRIPE_PRICE_ID_PRO_EUR=price_...         # €19/unidade/mês
STRIPE_PRICE_ID_STARTER_BRL=price_...     # R$49/unidade/mês
STRIPE_PRICE_ID_GROWTH_BRL=price_...      # R$79/unidade/mês
STRIPE_PRICE_ID_PRO_BRL=price_...         # R$109/unidade/mês

# Stripe — Metered prices (billing_scheme=per_unit, usage_type=metered, aggregate_usage=sum)
# Growth: €1 per booking — unit_amount=100 (€1.00), report 1 usage per booking
STRIPE_PRICE_ID_GROWTH_METERED_EUR=price_...
STRIPE_PRICE_ID_GROWTH_METERED_BRL=price_...
# Pro: 1% of revenue — unit_amount=1 (€0.01), report revenue_in_euros as usage
STRIPE_PRICE_ID_PRO_METERED_EUR=price_...
STRIPE_PRICE_ID_PRO_METERED_BRL=price_...

# Stripe Billing Meter event names (configure in Stripe Dashboard → Billing → Meters)
STRIPE_METER_EVENT_GROWTH=booking_fee   # Growth: 1 unit per booking
STRIPE_METER_EVENT_PRO=revenue_fee      # Pro: revenue_in_euros per booking (price=€0.01→1%)

# Legacy (backward compat — remove after migrating existing subscribers)
STRIPE_PRICE_ID_BRL=price_...
STRIPE_PRICE_ID_EUR=price_...

# App URL (sem barra final)
NEXT_PUBLIC_APP_URL=https://seudominio.com

# Preço mensal apresentado na landing page
NEXT_PUBLIC_MONTHLY_PRICE=29

# Booking.com Integration (Story 15.x — Connectivity Partner Program)
# Obter após aprovação em https://connectivity.booking.com
BOOKING_WEBHOOK_SECRET=          # HMAC-SHA256 secret para validar webhooks
BOOKING_CHANNEL_ENABLED=false    # Activar painel de canal (Story 15.3) — false por default
