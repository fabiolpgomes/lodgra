{
  "name": "@lodgra/design-tokens",
  "version": "1.0.0",
  "description": "Design tokens for Lodgra - semantic color, typography, spacing, and component tokens",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens.json": "./dist/tokens.json",
    "./tokens.yaml": "./tokens.yaml",
    "./css": "./dist/tokens.css",
    "./css/colors": "./dist/tokens/colors.css",
    "./css/typography": "./dist/tokens/typography.css",
    "./css/spacing": "./dist/tokens/spacing.css",
    "./css/components": "./dist/tokens/components.css"
  },
  "files": [
    "dist",
    "tokens.yaml",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "publish": "npm run build && npm publish"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "tokens",
    "colors",
    "typography",
    "spacing",
    "lodgra",
    "dtcg"
  ],
  "author": "Lodgra Team",
  "license": "MIT",
  "homepage": "https://github.com/fabiolpgomes/lodgra#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabiolpgomes/lodgra.git",
    "directory": "packages/design-tokens"
  },
  "bugs": {
    "url": "https://github.com/fabiolpgomes/lodgra/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
