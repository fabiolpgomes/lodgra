# E2E Test Configuration
# Copy this file to .env.test and fill in your values

# Supabase (required for app to function)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Test user credentials (required for authenticated tests)
TEST_USER_EMAIL=your-test-user@example.com
TEST_USER_PASSWORD=your-test-password

# Public property slug for booking flow tests (optional)
TEST_PROPERTY_SLUG=your-property-slug

# Base URL (defaults to http://localhost:3000)
# TEST_BASE_URL=http://localhost:3000
