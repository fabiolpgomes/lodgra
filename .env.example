# ============================================
# Home Stay — Environment Configuration
# ============================================
# Copy to .env.local (dev) or .env.test (e2e)
# DO NOT commit files with real credentials
# ============================================

# --------------------------------------------
# Supabase
# --------------------------------------------
# Production: Vercel → Environment Variables (Production scope)
# Staging:    Vercel → Environment Variables (Preview scope)
# Local:      .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --------------------------------------------
# Stripe
# --------------------------------------------
# Use sk_test_... for dev/staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BOOKING_WEBHOOK_SECRET=whsec_...

# --------------------------------------------
# Email (Resend)
# --------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM="Home Stay <info@contact.homestay.pt>"
EMAIL_ADMIN=admin@homestay.pt

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MONTHLY_PRICE=29
CRON_SECRET=your-cron-secret

# --------------------------------------------
# Rate Limiting (optional — fallback: in-memory)
# --------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --------------------------------------------
# E2E Testing (only in .env.test)
# --------------------------------------------
# Create this user in your staging Supabase project
# via Dashboard → Authentication → Add User
TEST_USER_EMAIL=e2e-test@homestay.pt
TEST_USER_PASSWORD=
# Base URL for Playwright (default: http://localhost:3000)
# For CI, point to the Vercel Preview URL
TEST_BASE_URL=http://localhost:3000
