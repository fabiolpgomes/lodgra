# ============================================
# Lodgra — Environment Configuration
# ============================================
# Copy to .env.local (dev) or .env.test (e2e)
# DO NOT commit files with real credentials
# ============================================

# --------------------------------------------
# Supabase
# --------------------------------------------
# Production: Vercel → Environment Variables (Production scope)
# Staging:    Vercel → Environment Variables (Preview scope)
# Local:      .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --------------------------------------------
# Stripe
# --------------------------------------------
# Use sk_test_... for dev/staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BOOKING_WEBHOOK_SECRET=whsec_...

# --------------------------------------------
# Asaas (PIX — Brazil)
# --------------------------------------------
# Per-organization keys stored in DB (organizations.asaas_api_key)
# The webhook validates the token against the org's stored key
# No global secret needed here

# --------------------------------------------
# Email (Resend)
# --------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM="Lodgra <info@lodgra.io>"
EMAIL_ADMIN=admin@lodgra.io

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MONTHLY_PRICE=97
CRON_SECRET=your-cron-secret

# --------------------------------------------
# Rate Limiting (optional — fallback: in-memory)
# --------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --------------------------------------------
# E2E Testing (only in .env.test)
# --------------------------------------------
# Create this user in your staging Supabase project
# via Dashboard → Authentication → Add User
TEST_USER_EMAIL=e2e-test@lodgra.io
TEST_USER_PASSWORD=
# Base URL for Playwright (default: http://localhost:3000)
# For CI, point to the Vercel Preview URL
TEST_BASE_URL=http://localhost:3000

# === AIOX Variables (added 2026-05-12) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Sentry (error tracking)
SENTRY_DSN=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=2.2.0

# AIOX_NOTE: The following variables already exist with different values:
# AIOX_SUGGESTED: SUPABASE_SERVICE_ROLE_KEY=
