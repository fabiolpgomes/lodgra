# ============================================
# Lodgra — Environment Configuration
# ============================================
# Copy to .env.local (dev) or .env.test (e2e)
# DO NOT commit files with real credentials
# ============================================

# --------------------------------------------
# Supabase
# --------------------------------------------
# Production: Vercel → Environment Variables (Production scope)
# Staging:    Vercel → Environment Variables (Preview scope)
# Local:      .env.local
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --------------------------------------------
# Stripe
# --------------------------------------------
# Use sk_test_... for dev/staging, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PLAN_STARTER_ID=price_...
STRIPE_PLAN_PROFESSIONAL_ID=price_...
STRIPE_PLAN_ENTERPRISE_ID=price_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BOOKING_WEBHOOK_SECRET=whsec_...

# Stripe — Per-unit licensed prices (billing_scheme=per_unit, usage_type=licensed)
STRIPE_PRICE_ID_STARTER_EUR=price_...
STRIPE_PRICE_ID_PROFESSIONAL_EUR=price_...
STRIPE_PRICE_ID_ENTERPRISE_EUR=price_...
STRIPE_PRICE_ID_STARTER_BRL=price_...
STRIPE_PRICE_ID_PROFESSIONAL_BRL=price_...
STRIPE_PRICE_ID_ENTERPRISE_BRL=price_...

# Stripe — Metered prices (booking fees, revenue %)
STRIPE_PRICE_ID_PROFESSIONAL_METERED_EUR=price_...
STRIPE_PRICE_ID_ENTERPRISE_METERED_EUR=price_...
STRIPE_PRICE_ID_PROFESSIONAL_METERED_BRL=price_...
STRIPE_PRICE_ID_ENTERPRISE_METERED_BRL=price_...

# Stripe Billing Meter event names
STRIPE_METER_EVENT_PROFESSIONAL=booking_fee
STRIPE_METER_EVENT_ENTERPRISE=revenue_fee

# Stripe BR/PT clients
STRIPE_BR_SECRET_KEY=sk_test_...
STRIPE_PT_SECRET_KEY=sk_test_...
STRIPE_BR_WEBHOOK_SECRET=whsec_...
STRIPE_PT_WEBHOOK_SECRET=whsec_...

# Stripe Booking Webhook
STRIPE_PRICE_ID_BUSINESS_BRL=price_...
STRIPE_PRICE_ID_BUSINESS_EUR=price_...
STRIPE_PRICE_ID_PROFESSIONAL_BRL=price_...
STRIPE_PRICE_ID_PROFESSIONAL_EUR=price_...

# Stripe Booking Integration
STRIPE_BOOKING_WEBHOOK_SECRET=whsec_...

# Legacy (backward compatibility — remove after migrating)
STRIPE_PRICE_ID_BRL=price_...
STRIPE_PRICE_ID_EUR=price_...

# --------------------------------------------
# Google OAuth
# --------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-api-key
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# Google Vacation Rentals Feed
GOOGLE_FEED_LOCATION_DEFAULT=your-feed-location
GOOGLE_FEED_MAX_PROPERTIES=100

# Google My Business — Reviews Sync (Story 27.3)
# Service Account for reading property reviews from Google My Business
# See: docs/GOOGLE_SERVICE_ACCOUNT_ROTATION.md for credential rotation
GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/google-service-account-key.json

# OTA API Keys — Reviews Integration
BOOKING_HOTEL_ID=your-booking-hotel-id
BOOKING_API_KEY=your-booking-api-key
AIRBNB_ACCESS_TOKEN=your-airbnb-access-token
REVIEWS_SYNC_SECRET=your-reviews-sync-secret-for-cron

# Booking.com Integration (Legacy)
BOOKING_WEBHOOK_SECRET=your-webhook-secret
BOOKING_CHANNEL_ENABLED=false

# Asaas (PIX — Brazil)
# Per-organization keys stored in DB (organizations.asaas_api_key)
# The webhook validates the token against the org's stored key
# No global secret needed here

# --------------------------------------------
# Email (Resend)
# --------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM="Home Stay <noreply@contact.homestay.pt>"
EMAIL_ADMIN=info@homestay.pt
EMAIL_PARSE_ENCRYPT_KEY=your-encryption-key

# Email iCal Parser (Gmail integration)
GOOGLE_EMAIL_ADDRESS=your-email@gmail.com
GOOGLE_EMAIL_APP_PASSWORD=your-app-password

# Supabase Email Forwarding
SUPABASE_EMAIL_WEBHOOK_URL=your-webhook-url

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MONTHLY_PRICE=97
CRON_SECRET=your-cron-secret

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-ga-id
NEXT_PUBLIC_GA_ID=your-ga-id
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-token
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# Rate Limiting (optional — fallback: in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Turbo Cache (monorepo builds)
TURBO_CACHE=remote:rw
TURBO_TOKEN=your-turbo-token

# Node environment
NODE_ENV=development

# E2E Testing (only in .env.test)
# Create this user in your staging Supabase project
TEST_USER_EMAIL=e2e-test@lodgra.io
TEST_USER_PASSWORD=your-test-password
TEST_BASE_URL=http://localhost:3000
